# Application configuration (non-secrets)
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200,http://localhost:5173

# Firebase (non-secret)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# Optional local dev fallback instead of inline credentials:
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ─── Secrets (never commit real values) ───────────────────────────────────────
GEMINI_API_KEY=
FIREBASE_API_KEY=

# Firebase Admin credentials (preferred for production)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional future secrets
# JWT_SECRET=
# SMTP_PASSWORD=

# Gemini tuning (non-secret)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=60000