{
  "name": "iv-backend-functions",
  "version": "1.0.0",
  "private": true,
  "description": "AI Interview Platform — Firebase Functions API",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node -r ts-node/register src/server.ts",
    "start": "node lib/server.js",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^6.3.2",
    "groq-sdk": "^1.3.0",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "razorpay": "^2.9.6",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
