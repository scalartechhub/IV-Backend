{
  "name": "ai-interviewer-backend",
  "version": "1.0.0",
  "description": "AI Interview Platform backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node -r ts-node/register src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prepare:functions": "npm run build && node scripts/prepare-functions.js",
    "build:functions": "npm run prepare:functions && npm --prefix functions run build",
    "deploy-firestore": "firebase deploy --only firestore --project=interview-89e09",
    "deploy-functions": "firebase deploy --only functions --force --project=interview-89e09",
    "emulators:start": "firebase emulators:start --project=interview-89e09",
    "sync:secrets": "node scripts/sync-firebase-secrets.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^2.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.2.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
